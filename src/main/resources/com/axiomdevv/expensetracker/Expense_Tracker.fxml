<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Root: StackPane
-->
<StackPane id="outer-bg"
           prefWidth="1150.0"
           prefHeight="720.0"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.axiomdevv.expensetracker.TrackerController">

    <fx:define>
        <ToggleGroup fx:id="chartToggleGroup"/>
        <ToggleGroup fx:id="barToggleGroup"/>
    </fx:define>

    <BorderPane id="main-container">
        <StackPane.margin>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </StackPane.margin>

        <!-- ===== TOP BAR ===== -->
        <top>
            <HBox id="top-bar" alignment="CENTER_LEFT" prefHeight="65.0">
                <children>
                    <Label id="appName" text="Expense Tracker">
                        <HBox.margin><Insets left="25.0"/></HBox.margin>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="darkModeToggle"
                                  id="dark-mode-toggle"
                                  text="🌙  Dark Mode"
                                  onAction="#toggleDarkMode">
                        <HBox.margin><Insets right="25.0"/></HBox.margin>
                    </ToggleButton>
                </children>
            </HBox>
        </top>

        <!-- ===== LEFT SIDEBAR ===== -->
        <left>
            <VBox id="left-side" prefWidth="230.0" spacing="8.0" BorderPane.alignment="CENTER">
                <children>
                    <Label text="Description"/>
                    <TextField fx:id="descriptionField">
                        <VBox.margin><Insets left="5.0" right="5.0"/></VBox.margin>
                    </TextField>

                    <Label text="Category"/>
                    <ComboBox fx:id="categoryBox"
                              maxWidth="1.7976931348623157E308"
                              promptText="Choose a category">
                        <VBox.margin><Insets left="5.0" right="5.0"/></VBox.margin>
                    </ComboBox>

                    <Label text="Date"/>
                    <DatePicker fx:id="datePicker"
                                maxWidth="1.7976931348623157E308"
                                promptText="mm/dd/yyyy">
                        <VBox.margin><Insets left="5.0" right="5.0"/></VBox.margin>
                    </DatePicker>

                    <Label text="Amount"/>
                    <TextField fx:id="amountField" maxWidth="1.7976931348623157E308">
                        <VBox.margin><Insets left="5.0" right="5.0"/></VBox.margin>
                    </TextField>

                    <HBox alignment="CENTER" spacing="8.0">
                        <children>
                            <Button id="add-button" fx:id="addButton"
                                    text="Add" onAction="#addData"
                                    prefWidth="95.0" HBox.hgrow="ALWAYS">
                                <HBox.margin><Insets left="5.0"/></HBox.margin>
                            </Button>
                            <Button id="clear-button" fx:id="clearButton"
                                    text="Clear" onAction="#clearFields"
                                    prefWidth="95.0" HBox.hgrow="ALWAYS">
                                <HBox.margin><Insets right="5.0"/></HBox.margin>
                            </Button>
                        </children>
                    </HBox>
                </children>
                <BorderPane.margin>
                    <Insets bottom="15.0" left="15.0" right="10.0" top="25.0"/>
                </BorderPane.margin>
            </VBox>
        </left>

        <!-- ===================================================================
             CENTER — ScrollPane wrapping all dynamic content
        =================================================================== -->
        <center>
            <ScrollPane id="center-scroll"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">

                <VBox id="center-content" spacing="16.0">
                    <padding>
                        <Insets top="15.0" right="15.0" bottom="24.0" left="10.0"/>
                    </padding>
                    <children>

                        <!-- ─────────────────────────────────────
                             STAT CARDS ROW
                        ───────────────────────────────────────── -->
                        <HBox spacing="12.0">
                            <children>

                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="Total Balance"/>
                                        <Label fx:id="totalBalance"
                                               styleClass="stat-value"
                                               text="0.00"/>
                                    </children>
                                </VBox>

                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="Total Income"/>
                                        <Label fx:id="totalIncome"
                                               styleClass="stat-value,income-value"
                                               text="0.00"/>
                                    </children>
                                </VBox>

                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="Total Expenses"/>
                                        <Label fx:id="totalExpenses"
                                               styleClass="stat-value,expenses-value"
                                               text="0.00"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- ─────────────────────────────────────
                             TABLE + PIE CHART (side by side)
                        ───────────────────────────────────────── -->
                        <HBox spacing="12.0" minHeight="360.0">
                            <children>

                                <!-- Table Section -->
                                <VBox id="table-side"
                                      alignment="TOP_CENTER"
                                      spacing="10.0"
                                      HBox.hgrow="ALWAYS">
                                    <children>

                                        <TableView fx:id="table"
                                                   VBox.vgrow="ALWAYS"
                                                   minHeight="310.0">
                                            <columns>
                                                <TableColumn fx:id="dateColumn"
                                                             text="Date"
                                                             prefWidth="110.0"/>
                                                <TableColumn fx:id="descriptionColumn"
                                                             text="Description"
                                                             prefWidth="130.0"/>
                                                <TableColumn fx:id="categoryColumn"
                                                             text="Category"
                                                             prefWidth="110.0"/>
                                                <TableColumn fx:id="amountColumn"
                                                             text="Amount"
                                                             prefWidth="100.0"/>
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                        </TableView>
                                        <Button id="delete-button"
                                                fx:id="deleteButton"
                                                text="Delete selected"
                                                onAction="#deleteData"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- ─────────────────────────────────────
                             AREA CHART
                        ───────────────────────────────────────── -->
                        <VBox id="chart-side"
                              alignment="TOP_CENTER"
                              prefWidth="310.0"
                              spacing="10.0">
                            <children>
                                <HBox alignment="CENTER">
                                    <children>
                                        <ToggleButton id="cat-toggle"
                                                      fx:id="categoryToggle"
                                                      text="By Category"
                                                      prefWidth="120.0"
                                                      selected="true"
                                                      toggleGroup="$chartToggleGroup"
                                                      onAction="#updateChart"/>
                                        <ToggleButton id="income-toggle"
                                                      fx:id="incomeExpenseToggle"
                                                      text="Income / Exp"
                                                      prefWidth="130.0"
                                                      toggleGroup="$chartToggleGroup"
                                                      onAction="#updateChart"/>
                                    </children>
                                </HBox>

                                <PieChart fx:id="pieChart"
                                          prefHeight="370.0"
                                          prefWidth="290.0"
                                          animated="true"
                                          legendVisible="true"
                                          labelsVisible="true"
                                          VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>

                        <VBox id="bar-chart-side" spacing="8.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="section-title"
                                               text="Expenses Over Time"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <ToggleButton id="day-toggle"
                                                      fx:id="dayToggle"
                                                      text="Daily"
                                                      toggleGroup="$barToggleGroup"
                                                      onAction="#updateBarChart"/>
                                        <ToggleButton id="month-toggle"
                                                      fx:id="monthToggle"
                                                      text="Monthly"
                                                      selected="true"
                                                      toggleGroup="$barToggleGroup"
                                                      onAction="#updateBarChart"/>
                                        <ToggleButton id="year-toggle"
                                                      fx:id="yearToggle"
                                                      text="Yearly"
                                                      toggleGroup="$barToggleGroup"
                                                      onAction="#updateBarChart"/>
                                    </children>
                                </HBox>

                                <AreaChart fx:id="barChart"
                                           prefHeight="420.0"
                                           animated="true"
                                           legendVisible="true"
                                           createSymbols="false">
                                    <xAxis>
                                        <CategoryAxis side="BOTTOM"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis side="LEFT"/>
                                    </yAxis>
                                </AreaChart>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>

</StackPane>
